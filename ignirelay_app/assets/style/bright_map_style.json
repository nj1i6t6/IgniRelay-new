{
  "version": 8,
  "name": "ResQMesh Bright",
  "sources": {
    "openmaptiles": {
      "type": "vector"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#f2efe9" }
    },
    {
      "id": "landcover-grass",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "class", "grass"],
      "paint": { "fill-color": "#d8e8c8", "fill-opacity": 0.6 }
    },
    {
      "id": "landcover-wood",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "class", "wood"],
      "paint": { "fill-color": "#add19e", "fill-opacity": 0.5 }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "paint": { "fill-color": "#e8e4e0", "fill-opacity": 0.5 }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": { "fill-color": "#c8e6a0", "fill-opacity": 0.6 }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "paint": { "fill-color": "#aad3df" }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "paint": { "line-color": "#aad3df", "line-width": 1.5 }
    },
    {
      "id": "boundary-admin",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": ["<=", "admin_level", 6],
      "paint": { "line-color": "#9e9cab", "line-width": 1, "line-dasharray": [3, 2] }
    },
    {
      "id": "road-path",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "path", "track"],
      "paint": {
        "line-color": "#cba",
        "line-width": 1,
        "line-dasharray": [2, 1]
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "minor", "service"],
      "paint": {
        "line-color": "#ffffff",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.5, 14, 2, 18, 6]
      }
    },
    {
      "id": "road-tertiary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "tertiary"],
      "paint": {
        "line-color": "#ffffff",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.5, 14, 4, 18, 10]
      }
    },
    {
      "id": "road-secondary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "secondary"],
      "paint": {
        "line-color": "#f9e9ac",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 1, 14, 5, 18, 12]
      }
    },
    {
      "id": "road-primary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "primary"],
      "paint": {
        "line-color": "#fcd6a4",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.5, 14, 5, 18, 14]
      }
    },
    {
      "id": "road-trunk",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "trunk"],
      "paint": {
        "line-color": "#fbb29a",
        "line-width": ["interpolate", ["linear"], ["zoom"], 5, 0.5, 14, 6, 18, 16]
      }
    },
    {
      "id": "road-motorway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "motorway"],
      "paint": {
        "line-color": "#e892a2",
        "line-width": ["interpolate", ["linear"], ["zoom"], 5, 0.5, 14, 6, 18, 18]
      }
    },
    {
      "id": "road-rail",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "rail"],
      "paint": {
        "line-color": "#bbb",
        "line-width": 2,
        "line-dasharray": [4, 2]
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 13,
      "paint": { "fill-color": "#d9d0c9", "fill-opacity": 0.7 }
    },
    {
      "id": "building-outline",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 14,
      "paint": { "line-color": "#c9b2a6", "line-width": 0.5 }
    },

    {
      "id": "road-label",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "minzoom": 12,
      "layout": {
        "text-field": "{name}",
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 10, 18, 14],
        "symbol-placement": "line",
        "text-font": ["Noto Sans Regular"]
      },
      "paint": { "text-color": "#555", "text-halo-color": "#ffffff", "text-halo-width": 2 }
    },
    {
      "id": "place-label-city",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["in", "class", "city", "town"],
      "layout": {
        "text-field": "{name}",
        "text-size": ["interpolate", ["linear"], ["zoom"], 5, 12, 14, 22],
        "text-font": ["Noto Sans Regular"]
      },
      "paint": { "text-color": "#333", "text-halo-color": "#ffffff", "text-halo-width": 2 }
    },
    {
      "id": "place-label-village",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["in", "class", "village", "suburb", "neighbourhood", "hamlet"],
      "minzoom": 10,
      "layout": {
        "text-field": "{name}",
        "text-size": ["interpolate", ["linear"], ["zoom"], 10, 10, 16, 16],
        "text-font": ["Noto Sans Regular"]
      },
      "paint": { "text-color": "#555", "text-halo-color": "#ffffff", "text-halo-width": 1.5 }
    },

    {
      "id": "resq-poi-shop",
      "type": "circle",
      "source": "openmaptiles",
      "source-layer": "poi",
      "minzoom": 15,
      "filter": ["in", "class", "grocery", "supermarket"],
      "paint": {
        "circle-color": "#00cc00",
        "circle-radius": ["interpolate", ["linear"], ["zoom"], 15, 5, 18, 9],
        "circle-stroke-color": "#ffffff",
        "circle-stroke-width": 1.5
      }
    },
    {
      "id": "resq-poi-pharmacy",
      "type": "circle",
      "source": "openmaptiles",
      "source-layer": "poi",
      "minzoom": 14,
      "filter": ["==", "class", "pharmacy"],
      "paint": {
        "circle-color": "#cc00cc",
        "circle-radius": ["interpolate", ["linear"], ["zoom"], 14, 5, 18, 9],
        "circle-stroke-color": "#ffffff",
        "circle-stroke-width": 1.5
      }
    },
    {
      "id": "resq-poi-school",
      "type": "circle",
      "source": "openmaptiles",
      "source-layer": "poi",
      "minzoom": 13,
      "filter": ["in", "class", "school", "college"],
      "paint": {
        "circle-color": "#ff9900",
        "circle-radius": ["interpolate", ["linear"], ["zoom"], 13, 6, 18, 11],
        "circle-stroke-color": "#ffffff",
        "circle-stroke-width": 2
      }
    },
    {
      "id": "resq-poi-police",
      "type": "circle",
      "source": "openmaptiles",
      "source-layer": "poi",
      "minzoom": 13,
      "filter": ["in", "class", "police"],
      "paint": {
        "circle-color": "#0033cc",
        "circle-radius": ["interpolate", ["linear"], ["zoom"], 13, 7, 18, 13],
        "circle-stroke-color": "#ffffff",
        "circle-stroke-width": 2
      }
    },
    {
      "id": "resq-poi-hospital",
      "type": "circle",
      "source": "openmaptiles",
      "source-layer": "poi",
      "minzoom": 12,
      "filter": ["in", "class", "hospital"],
      "paint": {
        "circle-color": "#cc0000",
        "circle-radius": ["interpolate", ["linear"], ["zoom"], 12, 7, 18, 15],
        "circle-stroke-color": "#ffffff",
        "circle-stroke-width": 2.5
      }
    },
    {
      "id": "resq-poi-label",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "poi",
      "minzoom": 14,
      "filter": ["in", "class", "hospital", "police", "school", "pharmacy", "college"],
      "layout": {
        "text-field": "{name}",
        "text-size": 12,
        "text-offset": [0, 1.3],
        "text-anchor": "top",
        "text-font": ["Noto Sans Regular"]
      },
      "paint": {
        "text-color": "#333333",
        "text-halo-color": "rgba(255, 255, 255, 0.9)",
        "text-halo-width": 2
      }
    }
  ]
}
